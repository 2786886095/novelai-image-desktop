{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["electron/main.ts", "electron/preload.ts", "electron/ipc/**/*.ts", "src/types.ts", "src/anlas.ts"],
  "exclude": ["electron/**/*.test.ts"]
}
